# ============================================================================
# APEX Environment Variables — copy to .env and fill in your keys
# ============================================================================

# Gemini API (Layer 6 — Foundation Model Agent)
# Get free key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Materials Project API (Materials domain — stretch goal)
MP_API_KEY=your_materials_project_api_key

# Logging
APEX_LOG_LEVEL=INFO
APEX_LOG_FILE=logs/apex.log

# API Server
APEX_API_HOST=0.0.0.0
APEX_API_PORT=8000

# Frontend
VITE_API_URL=http://localhost:8000
